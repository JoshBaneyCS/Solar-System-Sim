# Enforce LF line endings for source files (prevents CRLF issues on Windows)
*.go text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Makefile text eol=lf

# Mark generated/vendored files so GitHub Linguist ignores them in language stats

# Build artifacts
bin/** linguist-generated
crates/*/target/** linguist-generated

# Asset files (textures, models, meshes)
assets/textures/** linguist-generated
assets/models/** linguist-generated
assets/meshes/** linguist-generated
space-object-textures/** linguist-generated

# Rust lock files
Cargo.lock linguist-generated
crates/*/Cargo.lock linguist-generated

# IDE files
.idea/** linguist-generated
